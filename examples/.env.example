# examples/docker-compose.yml defaults — copy to .env and adjust for remote Headscale.
QUACK_TAILNET_TOKEN=quackscale-demo-token
HEADSCALE_USER=quackscale-demo
HEADSCALE_CONTROL_URL=http://127.0.0.1:8080
SERVER_HOST=quacktail-server
QUACK_PORT=9494
QUACK_FORWARD_LOCAL_PORT=19494

# Headscale preauth key (generated at bootstrap — NOT the Quack token above):
#   docker exec quacktail-server cat /work/authkey
#   docker exec quacktail-server cat /work/demo.env
# Save locally as examples/headscale/demo.authkey for scripts/local_remote_headscale_test.sh
# HEADSCALE_AUTHKEY=
