 	"unsafe"
 
 	"golang.org/x/sys/unix"
@@ -621,3 +622,67 @@ func TsnetEnableFunnelToLocalhostPlaintextHttp1(sd C.int, localhostPort C.int) C
 
 	return 0
 }
+
+//export TsnetServeLocalhostTCP
+func TsnetServeLocalhostTCP(sd C.int, listenPort C.int, localPort C.int) C.int {
+	s := getServer(sd)
+	if s == nil {
+		return C.EBADF
+	}
+	if listenPort <= 0 || listenPort > 65535 || localPort <= 0 || localPort > 65535 {
+		return s.recErr(fmt.Errorf("libtailscale: invalid port"))
+	}
+
+	ctx := context.Background()
+	lc, err := s.s.LocalClient()
+	if err != nil {
+		return s.recErr(err)
+	}
+
+	tcpForward := fmt.Sprintf("127.0.0.1:%d", localPort)
+	sc := &ipn.ServeConfig{
+		TCP: map[uint16]*ipn.TCPPortHandler{
+			uint16(listenPort): {
+				TCPForward: tcpForward,
+			},
+		},
+	}
+	return s.recErr(lc.SetServeConfig(ctx, sc))
+}
+
+//export TsnetClearServe
+func TsnetClearServe(sd C.int) C.int {
+	s := getServer(sd)
+	if s == nil {
+		return C.EBADF
+	}
+	ctx := context.Background()
+	lc, err := s.s.LocalClient()
+	if err != nil {
+		return s.recErr(err)
+	}
+	return s.recErr(lc.SetServeConfig(ctx, &ipn.ServeConfig{}))
+}
+
+//export TsnetPingTCP
+func TsnetPingTCP(sd C.int, host *C.char, port C.int, timeoutMs C.int) C.int {
+	s := getServer(sd)
+	if s == nil {
+		return C.EBADF
+	}
+	if port <= 0 || port > 65535 {
+		return s.recErr(fmt.Errorf("libtailscale: invalid port"))
+	}
+	if timeoutMs <= 0 {
+		timeoutMs = 5000
+	}
+	ctx, cancel := context.WithTimeout(context.Background(), time.Duration(timeoutMs)*time.Millisecond)
+	defer cancel()
+	addr := net.JoinHostPort(C.GoString(host), strconv.Itoa(int(port)))
+	conn, err := s.s.Dial(ctx, "tcp", addr)
+	if err != nil {
+		return s.recErr(err)
+	}
+	conn.Close()
+	return 0
+}
